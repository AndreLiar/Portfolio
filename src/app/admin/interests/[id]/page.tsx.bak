import { InterestForm } from '@/components/admin/interest-form';
import { interestApi } from '@/lib/api/interest-client';

export default async function EditInterestPage({ params }: { params: Promise<{ id: string }> }) {
  const { id } = await params;  const item = await interestApi.getInterest(params.id);

  return (
    <div>
      <h1 className="text-2xl font-bold mb-4">Edit Interest</h1>
      <InterestForm mode="edit" item={item} />
    </div>
  );
}
